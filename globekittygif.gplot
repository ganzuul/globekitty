set terminal gif size 450,310 background rgb 0xFF000000 animate delay 2
set output "globekitty450x310.gif"

unset border
unset title
unset key
unset xtics
unset ytics
unset ztics

set xrange [-1:1] # Adjust ranges to accommodate scaling and translation
set yrange [-1:1]
set zrange [-1:1]

x(u, v) = cos(u) * cos(v)
y(u, v) = cos(u) * sin(v)
z(u, v) = sin(u)

set hidden3d
set parametric
set angles degrees
set samples 128, 128
set isosamples 25, 25
set mapping spherical
set dummy u, v
set urange [-90:90]
set vrange [0:360]

frames = 360
rotation_increment = 1
time = 0
angle = 65
scale = 1.3
zscale = 1.5

set view angle, time, scale, zscale

# Plot the globe surface
splot x(u, v), y(u, v), z(u, v) with lines lc rgb 'blue' lw 2 notitle, \
      'world_110m.dat' with lines lc rgb 'green' lw 2 notitle

do for [i = 1:frames] {
    time = time + rotation_increment
    set view angle, time, scale, zscale
    replot
}
